rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: comments
    // Document ID: Auto-generated
    // Fields:
    //   - postId: string (required, max length 100) - The slug of the blog post
    //   - authorName: string (required, max length 50) - The name of the anonymous commenter
    //   - content: string (required, max length 1000) - The text of the comment
    //   - createdAt: timestamp (required) - When the comment was posted
    //
    // ===============================================================

    // Helper Functions
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidComment() {
      let data = request.resource.data;
      return hasRequiredFields(['postId', 'authorName', 'content', 'createdAt']) &&
             hasOnlyAllowedFields(['postId', 'authorName', 'content', 'createdAt']) &&
             data.postId is string && data.postId.size() > 0 && data.postId.size() <= 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.createdAt is timestamp &&
             data.createdAt == request.time; // Must be server timestamp
    }

    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;
      
      // Anyone can create a comment if it passes validation
      allow create: if isValidComment();
      
      // No updates or deletes allowed for anonymous comments
      allow update, delete: if false;
    }
  }
}
